# ─────────────────────────────────────────────────────────────────────────────
# AML Builder Service — Environment Configuration
# Copy this file to .env and fill in the values for your environment.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Service ──────────────────────────────────────────────────────────────────
SERVICE_PORT=8005
DEBUG=false

# ─── LLM ──────────────────────────────────────────────────────────────────────
LLM_PROVIDER=openai            # openai | lmstudio
LLM_MODEL=gpt-4o
LLM_MODEL_FAST=gpt-4o-mini
OPENAI_API_KEY=sk-...          # Required for LLM_PROVIDER=openai
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=4096

# For local LMStudio (only needed if LLM_PROVIDER=lmstudio)
# LLM_BASE_URL=http://127.0.0.1:1234/v1

# ─── Oracle DB ────────────────────────────────────────────────────────────────
ORACLE_DSN=your_host:1521/your_service
ORACLE_USER=your_db_user
ORACLE_PASSWORD=your_db_password
ORACLE_POOL_MIN=2
ORACLE_POOL_MAX=10

# ─── AML Domain Defaults ──────────────────────────────────────────────────────
AML_COUNTRY_CODE=400
AML_INST_CODE=1
AML_CREATED_BY=999
AML_DEFAULT_ACTIVE_FLAG=Y
AML_DEFAULT_VIOLATION_LEVEL=M
AML_DEFAULT_DEGREE_RISK_FLAG=M

# ─── PioTech AI (SQL Bridge) ───────────────────────────────────────────────────
PIOTECH_AI_URL=http://localhost:8001/chat/stream
PIOTECH_AI_TIMEOUT_SECONDS=120
PIOTECH_AI_USER_ID=aml_builder_agent
PIOTECH_AI_PROJECT_ID=0

# ─── LangGraph ────────────────────────────────────────────────────────────────
CHECKPOINT_DB_PATH=./artifacts/checkpoints.sqlite
MAX_AGENT_ITERATIONS=25
MAX_VALIDATION_RETRIES=3

# ─── LangSmith (Observability) ─────────────────────────────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=ai-aml-agent
